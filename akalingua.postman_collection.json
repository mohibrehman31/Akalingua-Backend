{
  "info": {
    "name": "Akalingua API",
    "_postman_id": "akalingua-collection-0001",
    "description": "Akalingua backend — student/tutor marketplace. Set the {{base_url}} and {{access_token}} collection variables before use. Most requests use Bearer auth inherited from the collection; public routes override auth to none.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{access_token}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" },
    { "key": "user_id", "value": "", "type": "string" },
    { "key": "tutor_id", "value": "", "type": "string" },
    { "key": "student_id", "value": "", "type": "string" },
    { "key": "job_post_id", "value": "", "type": "string" },
    { "key": "quote_id", "value": "", "type": "string" },
    { "key": "language_id", "value": "", "type": "string" },
    { "key": "credential_id", "value": "", "type": "string" },
    { "key": "notification_id", "value": "", "type": "string" }
